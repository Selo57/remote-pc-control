{
  "name": "remote-pc-control",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "description": "Windows remote PC control host with WebRTC streaming, mobile web client, Cloudflare tunnel supervision, and Discord notifications.",
  "scripts": {
    "dev": "concurrently -k -n HOST,WEB \"tsx watch src/host/main.ts\" \"vite --host 0.0.0.0\"",
    "dev:host": "tsx watch src/host/main.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "npm run build:web && npm run build:host",
    "build:web": "vite build",
    "build:host": "tsc -p tsconfig.host.json",
    "build:input": "dotnet build native/RemotePc.InputHost/RemotePc.InputHost.csproj -c Release",
    "publish:input": "dotnet publish native/RemotePc.InputHost/RemotePc.InputHost.csproj -c Release -r win-x64",
    "release:zip": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/create-release-zip.ps1",
    "host:local": "cross-env CLOUDFLARE_ENABLED=false node dist/host/main.js",
    "start": "node dist/host/main.js",
    "electron:dev": "concurrently -k -n HOST,ELECTRON,WEB \"tsx watch src/host/main.ts\" \"wait-on http://localhost:5173 && electron dist/host/electron-main.js\" \"vite --host 0.0.0.0\"",
    "electron:build-main": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.host.json --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "test": "tsx --test tests/*.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:prod": "npm audit --omit=dev --audit-level=critical",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build && npm run build:input && npm run audit:prod"
  },
  "dependencies": {
    "cookie": "1.1.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "lucide-react": "1.18.0",
    "nanoid": "5.1.11",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "werift": "0.23.0",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/cookie": "1.0.0",
    "@types/express": "5.0.6",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.5.0",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "42.4.0",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.0.16",
    "wait-on": "9.0.10"
  },
  "overrides": {
    "undici": "7.28.0"
  }
}
